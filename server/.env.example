PORT=5000

# MongoDB Atlas URI (Required)
# Get this from MongoDB Atlas Dashboard → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/Shop-V1?retryWrites=true&w=majority

# JWT Secret (Required - generate a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Client URL (Frontend)
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development

# Email Configuration (Gmail) - Optional
# EMAIL_USER=your.email@gmail.com
# EMAIL_PASS=your_gmail_app_password_here

# Production Frontend URLs (comma-separated, optional)
# PRODUCTION_URLS=https://myzshop.vercel.app,https://www.myzshop.tn
